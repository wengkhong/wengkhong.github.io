---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

interface NavItem {
  href: string;
  label: string;
}

const { title, description = "Personal academic website of Weng Khong Lim" } = Astro.props as Props;

const navItems: NavItem[] = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/research", label: "Research" },
  { href: "/publications", label: "Publications" },
  { href: "/tools", label: "Tools" },
  { href: "/grants", label: "Grants" },
  { href: "/talks", label: "Talks" },
  { href: "/contact", label: "Contact" }
];

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;
const current = (href: string) => (currentPath === href ? "page" : undefined);
const nav = (href: string) => navItems.find((item) => item.href === href)!;
const isMoreActive =
  currentPath === "/tools" ||
  currentPath === "/grants" ||
  currentPath === "/talks";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL("/WK_Profile.png", Astro.site)} />
    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>

    <header class="site-header">
      <div class="site-shell site-header-inner">
        <a class="site-brand" href="/">Weng Khong Lim, PhD</a>
        <nav class="site-nav" aria-label="Primary">
          <a href={nav("/").href} aria-current={current("/")}>{nav("/").label}</a>
          <a href={nav("/research").href} aria-current={current("/research")}>{nav("/research").label}</a>
          <a href={nav("/publications").href} aria-current={current("/publications")}>{nav("/publications").label}</a>
          <a href={nav("/contact").href} aria-current={current("/contact")}>{nav("/contact").label}</a>
          <details class="nav-more" data-active={isMoreActive ? "true" : "false"}>
            <summary>More</summary>
            <div class="nav-more-list">
              <a href={nav("/about").href} aria-current={current("/about")}>{nav("/about").label}</a>
              <a href={nav("/tools").href} aria-current={current("/tools")}>{nav("/tools").label}</a>
              <a href={nav("/grants").href} aria-current={current("/grants")}>{nav("/grants").label}</a>
              <a href={nav("/talks").href} aria-current={current("/talks")}>{nav("/talks").label}</a>
            </div>
          </details>
        </nav>
      </div>
    </header>

    <main id="main-content" class="site-shell">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-shell">
        <p>
          Computational genomics, clinical translation, and population-scale sequencing.
        </p>
        <p>
          <a href="/publications">Publications</a> · <a href="/research">Research</a> · <a href="/contact">Contact</a>
        </p>
      </div>
    </footer>
  </body>
</html>
