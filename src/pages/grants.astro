---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const grants = await getCollection("grants");
const active = grants.filter((g) => g.data.status === "active");
const completed = grants.filter((g) => g.data.status === "completed");
---

<MainLayout
  title="Grants and Projects | Weng Khong Lim"
  description="Active grants and translational genomics projects."
>
  <header class="section">
    <h1 class="page-title">Grants and Projects</h1>
    <p class="page-intro">
      Active and ongoing projects focused on scaling genomic medicine, improving variant interpretation,
      and strengthening translational deployment in healthcare.
    </p>
  </header>

  {active.length > 0 && (
    <section class="section">
      <div class="section-header">
        <h2>Active</h2>
      </div>
      <div class="grid two">
        {active.map((grant) => (
          <article class="card">
            <h3>{grant.data.title}</h3>
            <p class="eyebrow">{grant.data.fundingBody}{grant.data.role ? ` · ${grant.data.role}` : ""}</p>
            {grant.body && <p>{grant.body}</p>}
          </article>
        ))}
      </div>
    </section>
  )}

  {completed.length > 0 && (
    <section class="section">
      <div class="section-header">
        <h2>Completed</h2>
      </div>
      <div class="grid two">
        {completed.map((grant) => (
          <article class="card">
            <h3>{grant.data.title}</h3>
            <p class="eyebrow">{grant.data.fundingBody}</p>
            {grant.body && <p>{grant.body}</p>}
          </article>
        ))}
      </div>
    </section>
  )}
</MainLayout>
