---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Tools and Software | Weng Khong Lim"
  description="Tools and software for variant interpretation and genomic analysis."
>
  <header class="section">
    <h1 class="page-title">Tools and Software</h1>
    <p class="page-intro">
      Software systems that support clinical genomics interpretation workflows and large-scale genomic
      analysis.
    </p>
  </header>

  <section class="section grid two">
    <article class="card">
      <h2>Variant Interpretation</h2>
      <ul class="list-plain">
        <li>Automated ACMG classification frameworks</li>
        <li>Variant prioritisation pipelines</li>
        <li>Clinical reporting tools</li>
      </ul>
    </article>

    <article class="card">
      <h2>Genomic Analysis</h2>
      <ul class="list-plain">
        <li>Population variant annotation workflows</li>
        <li>Rare disease analysis pipelines</li>
        <li>Integration with sequencing platforms</li>
      </ul>
    </article>
  </section>

  <section class="section card">
    <h2>Ongoing Development</h2>
    <ul class="list-plain">
      <li>AI-assisted interpretation systems</li>
      <li>Literature-driven phenotype extraction</li>
    </ul>
  </section>
</MainLayout>
