---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const tools = await getCollection("tools");

const categories: Record<string, string> = {
  "variant-interpretation": "Variant Interpretation",
  "genomic-analysis": "Genomic Analysis",
  "ai": "AI & Data Science",
  "other": "Other",
};

const grouped: Record<string, typeof tools> = {};
for (const tool of tools) {
  const cat = tool.data.category;
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(tool);
}
---

<MainLayout
  title="Tools and Software | Weng Khong Lim"
  description="Tools and software for variant interpretation and genomic analysis."
>
  <header class="section">
    <h1 class="page-title">Tools and Software</h1>
    <p class="page-intro">
      Software systems that support clinical genomics interpretation workflows and large-scale genomic
      analysis.
    </p>
  </header>

  {Object.entries(grouped).map(([cat, catTools]) => (
    <section class="section">
      <div class="section-header">
        <h2>{categories[cat] || cat}</h2>
      </div>
      <div class="grid two">
        {catTools.map((tool) => (
          <article class="card">
            <h3>
              {tool.data.link
                ? <a href={tool.data.link} target="_blank" rel="noopener noreferrer">{tool.data.name}</a>
                : tool.data.name
              }
            </h3>
            {tool.data.status === "development" && <p class="eyebrow">In development</p>}
            {tool.body && <p>{tool.body}</p>}
          </article>
        ))}
      </div>
    </section>
  ))}
</MainLayout>
