---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const talks = await getCollection("talks");
const upcoming = talks.filter((t) => t.data.type === "upcoming").sort((a, b) => a.data.date.localeCompare(b.data.date));
const past = talks.filter((t) => t.data.type !== "upcoming").sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<MainLayout
  title="Talks | Weng Khong Lim"
  description="Invited talks and selected presentations in clinical and population genomics."
>
  <header class="section">
    <h1 class="page-title">Talks</h1>
    <p class="page-intro">
      Selected invited talks and conference presentations on variant interpretation, clinical genomics,
      and genomic medicine deployment.
    </p>
  </header>

  {upcoming.length > 0 && (
    <section class="section">
      <div class="section-header">
        <h2>Upcoming</h2>
      </div>
      {upcoming.map((talk) => (
        <article class="section card">
          <h3>{talk.data.title}</h3>
          <p class="eyebrow">{talk.data.venue}{talk.data.location ? ` · ${talk.data.location}` : ""}</p>
          {talk.body && <p>{talk.body}</p>}
        </article>
      ))}
    </section>
  )}

  {past.length > 0 && (
    <section class="section">
      <div class="section-header">
        <h2>Recent Talks</h2>
      </div>
      {past.map((talk) => (
        <article class="section card">
          <h3>{talk.data.title}</h3>
          <p class="eyebrow">{talk.data.venue}{talk.data.location ? ` · ${talk.data.location}` : ""}</p>
          {talk.body && <p>{talk.body}</p>}
        </article>
      ))}
    </section>
  )}
</MainLayout>
