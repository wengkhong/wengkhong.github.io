---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Talks | Weng Khong Lim"
  description="Invited talks and selected presentations in clinical and population genomics."
>
  <header class="section">
    <h1 class="page-title">Talks</h1>
    <p class="page-intro">
      Selected invited talks and conference presentations on variant interpretation, clinical genomics,
      and genomic medicine deployment.
    </p>
  </header>

  <section class="section card">
    <h2>Recent Topics</h2>
    <ul class="list-plain">
      <li>AI-assisted variant interpretation in clinical pipelines</li>
      <li>Population genomics for improved risk and diagnostic context</li>
      <li>Bridging sequencing and diagnosis in healthcare systems</li>
    </ul>
  </section>

  <section class="section card">
    <h2>Upcoming</h2>
    <p>
      Upcoming and newly confirmed talks will be listed here with venue, date, and presentation title.
    </p>
  </section>
</MainLayout>
