---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const publications = await getCollection("publications");
const featured = publications.filter((p) => p.data.featured);
const sorted = publications.sort((a, b) => b.data.year - a.data.year);
---

<MainLayout
  title="Publications | Weng Khong Lim"
  description="Selected publications in clinical and population genomics."
>
  <header class="section">
    <h1 class="page-title">Publications</h1>
    <p class="page-intro">
      Selected work focused on clinically relevant variant interpretation in ancestrally diverse Asian
      populations and translational genomics.
    </p>
  </header>

  {featured.map((pub) => (
    <section class="section card">
      <p class="eyebrow">Selected Publication</p>
      <h2>{pub.data.authors} ({pub.data.year})</h2>
      <p>
        {pub.data.title}.
        <em> {pub.data.journal}</em>.
      </p>
      {pub.body && <p>{pub.body}</p>}
    </section>
  ))}

  {sorted.length > 1 && (
    <section class="section card">
      <h3>All Publications</h3>
      <ul class="list-plain">
        {sorted.map((pub) => (
          <li>
            {pub.data.authors} ({pub.data.year}). {pub.data.title}. <em>{pub.data.journal}</em>.
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="section card">
    <h3>More Publications</h3>
    <p>Additional publications are available on Google Scholar.</p>
    <p>
      <a class="button-link secondary" href="https://scholar.google.com/citations?user=8lU-rEkAAAAJ&hl=en" aria-label="Google Scholar profile" target="_blank" rel="noopener noreferrer">
        Google Scholar
      </a>
    </p>
  </section>
</MainLayout>
